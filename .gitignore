# Git Ignore for LLM Wiki System

# System files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE/Editor files
.vscode/
.idea/
*.iml

# Obsidian cache and temporary files
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.trash/
.cache/

# Claude Code specific
.claude/
.claude-worktree/

# Python virtual environments
venv/
env/
.venv/

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Temporary files
temp/
tmp/

# Large binary files (should be in raw/assets/)
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.mp4
*.mov
*.avi

# Sensitive data (never commit these!)
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local
secrets.json
credentials.json
private.key
*.pem

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
ehthumbs.db
Icon?
._*

# Backup files
*.bak
*.backup
*.old

# Package files
node_modules/
package-lock.json
yarn.lock

# Documentation
_site/
.sass-cache/
.jekyll-cache/